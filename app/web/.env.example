## PocketBase
# Leave empty for defaults (web: 127.0.0.1, Android: 10.0.2.2).
# For REAL Android device on same Wi‑Fi, set to your PC's IP:
#   VITE_POCKETBASE_URL=http://10.109.11.180:8091
# CORS for Capacitor is configured in app/pocketbase/pb_hooks/cors-capacitor.pb.js
VITE_POCKETBASE_URL=http://192.168.55.102:8091

## AI Corrector API
# Endpoint should accept POST { imageBase64: "data:image/png;base64,..." }
# and respond with either:
# - { ghostLinesBase64: "data:image/png;base64,..." }  (preferred)
# - or raw image/png response body
VITE_AI_API_URL=

